NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-strong-random-secret-in-production

# Vercel KV – leave blank for local file-based storage (see README).
# The app accepts both the standard Vercel KV variable names and the prefixed
# variants that Vercel creates when the storage integration has a custom name
# (e.g. a store named "LEAVE_TRACKER_STORAGE" produces the second pair).
KV_REST_API_URL=
KV_REST_API_TOKEN=
# LEAVE_TRACKER_STORAGE_KV_REST_API_URL=
# LEAVE_TRACKER_STORAGE_KV_REST_API_TOKEN=
